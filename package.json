{
  "name": "market-signal-deck",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.7",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "ingest:market": "tsx scripts/market-ingestion.ts",
    "backfill:historical": "tsx scripts/historical-backfill.ts",
    "jobs:predictions": "tsx scripts/prediction-jobs.ts",
    "summary:daily": "tsx scripts/daily-summary.ts",
    "quality:data": "tsx scripts/data-quality.ts",
    "security:secrets": "tsx scripts/secret-scan.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "lightweight-charts": "^4.2.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.8"
  }
}
