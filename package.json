{
  "name": "market-signal-deck",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.7",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0",
    "lint": "next typegen && tsc --noEmit --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "ingest:market": "tsx scripts/market-ingestion.ts",
    "backfill:historical": "tsx scripts/historical-backfill.ts",
    "jobs:predictions": "tsx scripts/prediction-jobs.ts",
    "summary:daily": "tsx scripts/daily-summary.ts",
    "quality:data": "tsx scripts/data-quality.ts",
    "security:secrets": "tsx scripts/secret-scan.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "lightweight-charts": "^4.2.3",
    "lucide-react": "^0.468.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "next>postcss": "8.5.15",
